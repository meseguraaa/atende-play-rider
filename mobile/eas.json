{
    "cli": {
        "version": ">= 18.1.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview"
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "env": {
                "BRAND_SLUG": "atendeplay",
                "EXPO_PUBLIC_API_URL": "https://atendeplay.atendeplay.com.br"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
